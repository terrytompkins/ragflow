# -----------------------------------------------------------------------------
# RAGFlow environment variables (ECS task definition reference)
# -----------------------------------------------------------------------------
# These are the key variables passed to the RAGFlow container.
# Terraform injects these from infrastructure outputs.
# Add additional overrides here for deployment-specific config.
# -----------------------------------------------------------------------------

# Document engine: opensearch | elasticsearch | infinity
DOC_ENGINE=opensearch

# Storage: AWS_S3 | MINIO
STORAGE_IMPL=AWS_S3

# CPU for DeepDoc (use gpu for GPU acceleration)
DEVICE=cpu

# MySQL (from RDS)
# MYSQL_HOST, MYSQL_PORT, MYSQL_DBNAME, MYSQL_USER, MYSQL_PASSWORD

# OpenSearch - use OS_HOSTS for full URL (AWS OpenSearch)
# OS_HOSTS=https://your-domain.us-east-1.es.amazonaws.com
# OPENSEARCH_PASSWORD, OS_USER=admin

# Redis (from ElastiCache)
# REDIS_HOST, REDIS_PORT, REDIS_PASSWORD

# S3 (from Terraform)
# S3_BUCKET, AWS_REGION
# For IAM role: omit AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY

# Optional
# TZ=America/New_York
# REGISTER_ENABLED=1
# LOG_LEVELS=ragflow=INFO
# MAX_CONTENT_LENGTH=134217728
# DOC_BULK_SIZE=4
# EMBEDDING_BATCH_SIZE=16

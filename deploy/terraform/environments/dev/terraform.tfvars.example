# -----------------------------------------------------------------------------
# RAGFlow dev environment - Terraform variables (future use)
# -----------------------------------------------------------------------------
# Copy from devtest and adjust for dev-specific settings.
# -----------------------------------------------------------------------------

environment = "dev"
aws_region  = "us-east-1"

availability_zones   = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs  = ["10.1.1.0/24", "10.1.2.0/24"]
private_subnet_cidrs = ["10.1.10.0/24", "10.1.11.0/24"]

rds_instance_class    = "db.t3.micro"
rds_allocated_storage = 20
rds_db_name           = "rag_flow"
rds_master_password   = "REPLACE_ME"

opensearch_instance_type   = "t3.small.search"
opensearch_instance_count  = 1
opensearch_ebs_volume_size = 10
opensearch_master_password = "REPLACE_ME"

elasticache_node_type   = "cache.t3.micro"
elasticache_num_nodes   = 1
elasticache_auth_token  = "REPLACE_ME"

ragflow_image_tag = "latest"
ecs_cpu          = 1024
ecs_memory       = 2048

domain_name          = ""
acm_certificate_arn  = ""
